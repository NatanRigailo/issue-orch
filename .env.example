# Comma-separated absolute paths to local repo clones
REPOS=/home/user/git/my-repo

# Cron expression for the scheduler (default: weekdays at 9am)
SCHEDULE=0 9 * * 1-5

# Max issues to implement per run (recommended: 1)
MAX_ISSUES_PER_RUN=1

# Timeout in seconds for the claude subprocess
CLAUDE_TIMEOUT=1800

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
